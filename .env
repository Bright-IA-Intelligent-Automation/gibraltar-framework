# Timezone
TZ=UTC

# Ignition
IGNITION_ADMIN_USERNAME=admin
IGNITION_ADMIN_PASSWORD=Ignition123!

# PostgreSQL
POSTGRES_USER=ignition
POSTGRES_PASSWORD=Ignition123!

# Ansible CD Runner
GIT_REPO_URL=https://github.com/Bright-IA-Intelligent-Automation/gibraltar-framework.git
GIT_BRANCH=main
CD_POLL_INTERVAL=300
IGNITION_SOURCE_REPO_URL=https://github.com/Bright-IA-Intelligent-Automation/gibraltar-ignition-src.git
IGNITION_SOURCE_REPO_BRANCH=master
IGNITION_SOURCE_SUBPATH=
